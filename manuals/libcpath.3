.Dd June 12, 2026
.Dt LIBCPATH 3
.Os
.Sh NAME
.Nm libcpath.h
.Nd Library to support cross-platform C path functions
.Sh SYNOPSIS
.In libcpath.h
.Pp
Support functions
.nf
.Ft const char *
.Fo libcpath_get_version
.Fa "void"
.Fc
.fi
.nf
.Ft int
.Fo libcpath_get_codepage
.Fa "int *codepage"
.Fa "libcpath_error_t **error"
.Fc
.fi
.nf
.Ft int
.Fo libcpath_set_codepage
.Fa "int codepage"
.Fa "libcpath_error_t **error"
.Fc
.fi
.Pp
Error functions
.nf
.Ft void
.Fo libcpath_error_free
.Fa "libcpath_error_t **error"
.Fc
.fi
.nf
.Ft int
.Fo libcpath_error_fprint
.Fa "libcpath_error_t *error"
.Fa "FILE *stream"
.Fc
.fi
.nf
.Ft int
.Fo libcpath_error_sprint
.Fa "libcpath_error_t *error"
.Fa "char *string"
.Fa "size_t size"
.Fc
.fi
.nf
.Ft int
.Fo libcpath_error_backtrace_fprint
.Fa "libcpath_error_t *error"
.Fa "FILE *stream"
.Fc
.fi
.nf
.Ft int
.Fo libcpath_error_backtrace_sprint
.Fa "libcpath_error_t *error"
.Fa "char *string"
.Fa "size_t size"
.Fc
.fi
.Pp
Path functions
.nf
.Ft int
.Fo libcpath_path_change_directory
.Fa "const char *directory_name"
.Fa "libcpath_error_t **error"
.Fc
.fi
.nf
.Ft int
.Fo libcpath_path_get_current_working_directory
.Fa "char **current_working_directory"
.Fa "size_t *current_working_directory_size"
.Fa "libcpath_error_t **error"
.Fc
.fi
.nf
.Ft int
.Fo libcpath_path_get_full_path
.Fa "const char *path"
.Fa "size_t path_length"
.Fa "char **full_path"
.Fa "size_t *full_path_size"
.Fa "libcpath_error_t **error"
.Fc
.fi
.nf
.Ft int
.Fo libcpath_path_get_sanitized_filename
.Fa "const char *filename"
.Fa "size_t filename_length"
.Fa "char **sanitized_filename"
.Fa "size_t *sanitized_filename_size"
.Fa "libcpath_error_t **error"
.Fc
.fi
.nf
.Ft int
.Fo libcpath_path_get_sanitized_path
.Fa "const char *path"
.Fa "size_t path_length"
.Fa "char **sanitized_path"
.Fa "size_t *sanitized_path_size"
.Fa "libcpath_error_t **error"
.Fc
.fi
.nf
.Ft int
.Fo libcpath_path_join
.Fa "char **path"
.Fa "size_t *path_size"
.Fa "const char *directory_name"
.Fa "size_t directory_name_length"
.Fa "const char *filename"
.Fa "size_t filename_length"
.Fa "libcpath_error_t **error"
.Fc
.fi
.nf
.Ft int
.Fo libcpath_path_make_directory
.Fa "const char *directory_name"
.Fa "libcpath_error_t **error"
.Fc
.fi
.Pp
Available when compiled with wide character string support:
.nf
.Ft int
.Fo libcpath_path_change_directory_wide
.Fa "const wchar_t *directory_name"
.Fa "libcpath_error_t **error"
.Fc
.fi
.nf
.Ft int
.Fo libcpath_path_get_current_working_directory_wide
.Fa "wchar_t **current_working_directory"
.Fa "size_t *current_working_directory_size"
.Fa "libcpath_error_t **error"
.Fc
.fi
.nf
.Ft int
.Fo libcpath_path_get_full_path_wide
.Fa "const wchar_t *path"
.Fa "size_t path_length"
.Fa "wchar_t **full_path"
.Fa "size_t *full_path_size"
.Fa "libcpath_error_t **error"
.Fc
.fi
.nf
.Ft int
.Fo libcpath_path_get_sanitized_filename_wide
.Fa "const wchar_t *filename"
.Fa "size_t filename_length"
.Fa "wchar_t **sanitized_filename"
.Fa "size_t *sanitized_filename_size"
.Fa "libcpath_error_t **error"
.Fc
.fi
.nf
.Ft int
.Fo libcpath_path_get_sanitized_path_wide
.Fa "const wchar_t *path"
.Fa "size_t path_length"
.Fa "wchar_t **sanitized_path"
.Fa "size_t *sanitized_path_size"
.Fa "libcpath_error_t **error"
.Fc
.fi
.nf
.Ft int
.Fo libcpath_path_join_wide
.Fa "wchar_t **path"
.Fa "size_t *path_size"
.Fa "const wchar_t *directory_name"
.Fa "size_t directory_name_length"
.Fa "const wchar_t *filename"
.Fa "size_t filename_length"
.Fa "libcpath_error_t **error"
.Fc
.fi
.nf
.Ft int
.Fo libcpath_path_make_directory_wide
.Fa "const wchar_t *directory_name"
.Fa "libcpath_error_t **error"
.Fc
.fi
.Sh DESCRIPTION
The
.Fn libcpath_get_version
function is used to retrieve the library version.
.Sh RETURN VALUES
Most of the functions return NULL or \-1 on error, dependent on the return \
type.
For the actual return values see
.In libcpath.h .
.Sh ENVIRONMENT
None
.Sh FILES
None
.Sh NOTES
libcpath can be compiled with wide character support (wchar_t).
.sp
To compile libcpath with wide character support use:
.Ar ./configure --enable-wide-character-type
 or define:
.Ar _UNICODE
 or
.Ar UNICODE
 during compilation.
.sp
.Ar LIBCPATH_WIDE_CHARACTER_TYPE
 in libcpath/features.h can be used to determine if libcpath was compiled with wide character support.
.Sh SEE ALSO
.In libcpath.h
